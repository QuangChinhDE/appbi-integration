# Database
DATABASE_URL=postgresql://integrationhub:integrationhub_password_2026@postgres:5432/integrationhub

# Security
SECRET_KEY=change-this-secret-key-in-production-2026

# CORS
CORS_ORIGINS=http://localhost:3002,http://localhost:8010

# Runtime
ENV=development

# Bootstrap admin
AUTH_BOOTSTRAP_ENABLED=true
AUTH_BOOTSTRAP_PRESET=admin
ADMIN_EMAIL=admin@appbi.local
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Platform Admin

# Module feature flags
FEATURE_MODULE_BACKUP_ENABLED=true
FEATURE_MODULE_APPS_ENABLED=true
FEATURE_MODULE_PIPELINE_ENABLED=true
FEATURE_MODULE_AUTOMATION_ENABLED=true
FEATURE_MODULE_SETTINGS_ENABLED=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8010/api/google/callback

# ============================================================
# AppBI Integration - Docker environment template
#
# Usage:
#   cp .env.example .env
#   edit .env
#   docker compose up -d --build
#
# Design rules for this file:
# - Keep only variables that Docker/services actually read
# - Group by concern: ports, database, security, OAuth, optional integrations
# - Provide safe local defaults when possible
# - Leave secrets empty so each machine fills its own values
# ============================================================

# ------------------------------------------------------------
# 1) Host ports
# Keep these different from appbi-ai so both projects can run together.
# ------------------------------------------------------------
FRONTEND_PORT=3002
BACKEND_PORT=8010
POSTGRES_PORT=5434

# ------------------------------------------------------------
# 2) PostgreSQL container settings
# These values are used by Docker Compose to build DATABASE_URL internally.
# ------------------------------------------------------------
POSTGRES_DB=integrationhub
POSTGRES_USER=integrationhub
POSTGRES_PASSWORD=change-this-db-password

# ------------------------------------------------------------
# 3) Backend security and browser access
# SECRET_KEY should be unique on every machine/environment.
# Example:
#   openssl rand -hex 32
# ------------------------------------------------------------
SECRET_KEY=change-this-secret-key-in-production
CORS_ORIGINS=http://localhost:3002,http://localhost:8010

# ------------------------------------------------------------
# 4) Google OAuth for Sign-In / Google Drive / Google Sheets
# Google Cloud Console -> Authorized JavaScript origins:
#   http://localhost:3002
# Google Cloud Console -> Authorized redirect URIs:
#   http://localhost:8010/api/google/callback
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8010/api/google/callback

# ------------------------------------------------------------
# 5) Optional shared platform service account
# Leave empty unless you want one shared Google credential for all users/flows.
# GCP_SERVICE_ACCOUNT_JSON should be a single-line JSON string.
# ------------------------------------------------------------
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_SERVICE_ACCOUNT_JSON=
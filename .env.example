# ╔══════════════════════════════════════════════════════════════╗
# ║  AppBI Integration — Unified Environment Configuration     ║
# ║                                                            ║
# ║  Variable naming is aligned with appbi-ai so both projects ║
# ║  can be maintained together. Where a variable is unique to ║
# ║  this app (e.g. Google Drive OAuth, service-account split  ║
# ║  fields for backup destinations) it is still documented.   ║
# ║                                                            ║
# ║  Quick start:                                               ║
# ║    cp .env.example .env                                     ║
# ║    # Fill in all CHANGE_ME values                           ║
# ║    docker compose up -d --build                             ║
# ╚══════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────┐
# │  1. ENVIRONMENT MODE                                         │
# │  Used by: backend                                            │
# └──────────────────────────────────────────────────────────────┘
# "production" (default) — enforces secure defaults.
# "development" — skips HTTPS-only cookie flag, relaxes validation.
ENVIRONMENT=production


# ┌──────────────────────────────────────────────────────────────┐
# │  2. DATABASE                                     [REQUIRED]  │
# │  Used by: postgres container, backend                        │
# └──────────────────────────────────────────────────────────────┘
# The postgres image reads POSTGRES_* directly — keep this prefix.
POSTGRES_DB=integrationhub
POSTGRES_USER=integrationhub
POSTGRES_PASSWORD=CHANGE_ME


# ┌──────────────────────────────────────────────────────────────┐
# │  3. SECURITY                                     [REQUIRED]  │
# │  Used by: backend, frontend                                  │
# └──────────────────────────────────────────────────────────────┘
# Random string for JWT signing.
# Generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Cookie secure flag. Set to "false" only for local HTTP development.
# Matches appbi-ai convention — cookies are httpOnly and SameSite=Lax.
COOKIE_SECURE=false

# JWT access-token lifetime in minutes.
AUTH_JWT_EXPIRE_MINUTES=480


# ┌──────────────────────────────────────────────────────────────┐
# │  4. ADMIN ACCOUNT                                [REQUIRED]  │
# │  Used by: backend (first-boot seed)                          │
# └──────────────────────────────────────────────────────────────┘
# Auto-created on first boot if the users table is empty.
ADMIN_EMAIL=admin@appbi.local
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Platform Admin


# ┌──────────────────────────────────────────────────────────────┐
# │  5. AUTH PROVIDERS                                           │
# │  Used by: backend, frontend                                  │
# └──────────────────────────────────────────────────────────────┘
AUTH_PASSWORD_LOGIN_ENABLED=true
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
# Optional comma-separated allowlist such as: yourcompany.com,subsidiary.com
AUTH_GOOGLE_ALLOWED_DOMAINS=
# false = only pre-created users can sign in with Google.
# true  = first Google sign-in auto-creates a new active user.
AUTH_GOOGLE_AUTO_CREATE_USERS=false
# Optional one-time bootstrap admin for Google login.
# If this email signs in with Google before being created,
# it is auto-created with full admin permissions.
AUTH_GOOGLE_BOOTSTRAP_ADMIN_EMAIL=

# Frontend login UI flags (Vite build-time).
VITE_AUTH_PASSWORD_ENABLED=true
VITE_AUTH_GOOGLE_ENABLED=false
VITE_GOOGLE_CLIENT_ID=


# ┌──────────────────────────────────────────────────────────────┐
# │  6. DOMAIN / URLS                                            │
# │  Used by: backend                                            │
# └──────────────────────────────────────────────────────────────┘
# Allow requests from these origins (comma-separated).
CORS_ORIGINS=http://localhost:3002,http://localhost:8010


# ┌──────────────────────────────────────────────────────────────┐
# │  7. HOST PORT MAPPING                                        │
# │  Used by: docker-compose port bindings                       │
# └──────────────────────────────────────────────────────────────┘
# Kept different from appbi-ai so both apps can run side by side.
FRONTEND_PORT=3002
BACKEND_PORT=8010
POSTGRES_PORT=5434


# ┌──────────────────────────────────────────────────────────────┐
# │  8. GOOGLE OAUTH — DATA ACCESS           [integration-only]  │
# │  Used by: backend (Google Drive, Google Sheets backups)      │
# │                                                              │
# │  These are separate from the sign-in credentials above:      │
# │  sign-in uses AUTH_GOOGLE_CLIENT_ID only, while data access  │
# │  (Drive/Sheets) needs full client_id + client_secret +       │
# │  redirect_uri registered in Google Cloud Console:            │
# │    Authorized JavaScript origins:                            │
# │      http://localhost:3002                                   │
# │    Authorized redirect URIs:                                 │
# │      http://localhost:8010/api/google/callback               │
# └──────────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8010/api/google/callback


# ┌──────────────────────────────────────────────────────────────┐
# │  9. GCP SERVICE ACCOUNT (optional)        [integration-only] │
# │  Used by: backend (Drive/Sheets writes without user OAuth)   │
# │                                                              │
# │  When set, backup flows can reuse one service account        │
# │  instead of asking each user to connect their Google         │
# │  account. Use EITHER the split fields (preferred) OR the     │
# │  single JSON blob (legacy fallback).                         │
# └──────────────────────────────────────────────────────────────┘
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_SERVICE_ACCOUNT_TYPE=service_account
GCP_SERVICE_ACCOUNT_PROJECT_ID=
GCP_SERVICE_ACCOUNT_PRIVATE_KEY_ID=
# Keep line breaks in the key as literal \n sequences.
GCP_SERVICE_ACCOUNT_PRIVATE_KEY=
GCP_SERVICE_ACCOUNT_CLIENT_EMAIL=
GCP_SERVICE_ACCOUNT_CLIENT_ID=
GCP_SERVICE_ACCOUNT_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_SERVICE_ACCOUNT_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_SERVICE_ACCOUNT_CLIENT_X509_CERT_URL=
GCP_SERVICE_ACCOUNT_UNIVERSE_DOMAIN=googleapis.com
# Legacy single-blob alternative to the fields above.
GCP_SERVICE_ACCOUNT_JSON=
